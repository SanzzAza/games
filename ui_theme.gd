static func create_theme() -> Theme:\n\tvar theme = Theme.new()\n\t\n\t# Button styles\n\tvar btn_normal = StyleBoxFlat.new()\n\tbtn_normal.bg_color = Color(0.2, 0.15, 0.3, 0.9)\n\tbtn_normal.border_color = Color(0.5, 0.3, 0.8, 1)\n\tbtn_normal.border_width_left = 2\n\tbtn_normal.border_width_right = 2\n\tbtn_normal.border_width_top = 2\n\tbtn_normal.border_width_bottom = 2\n\tbtn_normal.corner_radius_top_left = 8\n\tbtn_normal.corner_radius_top_right = 8\n\tbtn_normal.corner_radius_bottom_left = 8\n\tbtn_normal.corner_radius_bottom_right = 8\n\ttheme.set_stylebox(\"normal\", \"Button\", btn_normal)\n\t\n\tvar btn_hover = StyleBoxFlat.new()\n\tbtn_hover.bg_color = Color(0.3, 0.2, 0.5, 1)\n\tbtn_hover.border_color = Color(1, 0.8, 0.3, 1)\n\tbtn_hover.border_width_left = 2\n\tbtn_hover.border_width_right = 2\n\tbtn_hover.border_width_top = 2\n\tbtn_hover.border_width_bottom = 2\n\tbtn_hover.corner_radius_top_left = 8\n\tbtn_hover.corner_radius_top_right = 8\n\tbtn_hover.corner_radius_bottom_left = 8\n\tbtn_hover.corner_radius_bottom_right = 8\n\ttheme.set_stylebox(\"hover\", \"Button\", btn_hover)\n\t\n\tvar btn_pressed = StyleBoxFlat.new()\n\tbtn_pressed.bg_color = Color(0.1, 0.5, 0.6, 1)\n\tbtn_pressed.border_color = Color(0.3, 1, 0.9, 1)\n\tbtn_pressed.border_width_left = 2\n\tbtn_pressed.border_width_right = 2\n\tbtn_pressed.border_width_top = 2\n\tbtn_pressed.border_width_bottom = 2\n\tbtn_pressed.corner_radius_top_left = 8\n\tbtn_pressed.corner_radius_top_right = 8\n\tbtn_pressed.corner_radius_bottom_left = 8\n\tbtn_pressed.corner_radius_bottom_right = 8\n\ttheme.set_stylebox(\"pressed\", \"Button\", btn_pressed)\n\t\n\tvar btn_disabled = StyleBoxFlat.new()\n\tbtn_disabled.bg_color = Color(0.15, 0.15, 0.15, 0.5)\n\tbtn_disabled.border_color = Color(0.3, 0.3, 0.3, 1)\n\tbtn_disabled.border_width_left = 2\n\tbtn_disabled.border_width_right = 2\n\tbtn_disabled.border_width_top = 2\n\tbtn_disabled.border_width_bottom = 2\n\tbtn_disabled.corner_radius_top_left = 8\n\tbtn_disabled.corner_radius_top_right = 8\n\tbtn_disabled.corner_radius_bottom_left = 8\n\tbtn_disabled.corner_radius_bottom_right = 8\n\ttheme.set_stylebox(\"disabled\", \"Button\", btn_disabled)\n\t\n\t# Panel styles\n\tvar panel_style = StyleBoxFlat.new()\n\tpanel_style.bg_color = Color(0.1, 0.08, 0.15, 0.95)\n\tpanel_style.border_color = Color(0.6, 0.4, 0.9, 1)\n\tpanel_style.border_width_left = 3\n\tpanel_style.border_width_right = 3\n\tpanel_style.border_width_top = 3\n\tpanel_style.border_width_bottom = 3\n\tpanel_style.corner_radius_top_left = 12\n\tpanel_style.corner_radius_top_right = 12\n\tpanel_style.corner_radius_bottom_left = 12\n\tpanel_style.corner_radius_bottom_right = 12\n\ttheme.set_stylebox(\"panel\", \"Panel\", panel_style)\n\t\n\t# Label colors\n\ttheme.set_color(\"font_color\", \"Label\", Color(1, 1, 1, 1))\n\ttheme.set_font_size(\"font_size\", \"Label\", 14)\n\t\n\t# Button colors\n\ttheme.set_color(\"font_color\", \"Button\", Color(1, 1, 1, 1))\n\ttheme.set_color(\"font_hover_color\", \"Button\", Color(1, 0.9, 0.3, 1))\n\ttheme.set_color(\"font_pressed_color\", \"Button\", Color(0.3, 1, 0.9, 1))\n\ttheme.set_color(\"font_disabled_color\", \"Button\", Color(0.5, 0.5, 0.5, 1))\n\t\n\treturn theme\n"